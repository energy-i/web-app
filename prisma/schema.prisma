// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Organisation {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  email     String?
  address   String?
  createdAt DateTime
  updatedAt DateTime
  users     User[]
  sites     Site[]

  @@map("organisation")
}

model User {
  id             String       @id @default(uuid()) @db.Uuid
  name           String
  email          String
  emailVerified  Boolean
  image          String?
  createdAt      DateTime
  updatedAt      DateTime
  organisationId String       @db.Uuid
  organisation   Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  sessions       Session[]
  accounts       Account[]

  role       String?
  banned     Boolean?  @default(false)
  banReason  String?
  banExpires DateTime?

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id @default(uuid()) @db.Uuid
  expiresAt DateTime
  token     String
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  impersonatedBy String?

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id @default(uuid()) @db.Uuid
  accountId             String
  providerId            String
  userId                String    @db.Uuid
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String    @id @default(uuid()) @db.Uuid
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@index([identifier])
  @@map("verification")
}

enum MeterType {
  SMETS2
  SMETS1
  LEGACY
  SUB
}

model Site {
  id             String       @id @default(uuid()) @db.Uuid
  name           String
  addressLine1   String
  city           String
  postcode       String
  sector         String?
  latitude       Float?
  longitude      Float?
  area           Float?
  eac            Float?
  commsVendor    String?
  commsId        String?
  meterType      MeterType?
  createdAt      DateTime
  updatedAt      DateTime
  organisationId String       @db.Uuid
  organisation   Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  appliances     Appliance[]
  areas          Area[]
  tariff         Tariff?      @relation(fields: [tariffId], references: [id])
  tariffId       String?      @db.Uuid

  @@map("site")
}

model Tariff {
  id                      String    @id @default(uuid()) @db.Uuid
  name                    String
  supplier                String
  ratePerKwh              Float
  standingCharge          Float
  standingChargeFrequency String
  capacityCharge          Float?
  capacityChargeUnit      String?
  climateChangeLevy       Float?
  climateChangeLevyUnit   String?
  renewalDate             DateTime?
  createdAt               DateTime
  updatedAt               DateTime
  sites                   Site[]

  @@map("tariff")
}

model Area {
  id         String      @id @default(uuid()) @db.Uuid
  name       String
  createdAt  DateTime
  updatedAt  DateTime
  siteId     String      @db.Uuid
  site       Site        @relation(fields: [siteId], references: [id], onDelete: Cascade)
  appliances Appliance[]

  @@map("areas")
}

model Appliance {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  model     String
  serial    String
  createdAt DateTime
  updatedAt DateTime
  siteId    String   @db.Uuid
  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  areaId    String?  @db.Uuid
  area      Area?    @relation(fields: [areaId], references: [id], onDelete: Cascade)

  @@map("appliance")
}
